ARG PYTHON_VERSION=3.12
ARG REGISTRY=ghcr.io/snoodleboot-io
FROM ${REGISTRY}/pirn-ci-base:py${PYTHON_VERSION}

# Warm the uv cache with the heavy ML wheels (torch/tensorflow) so the
# heavy-tests job's fresh per-package install is fast. No workspace/lock — these
# are plain top-level installs that populate the shared uv cache. tensorflow is
# gated to python<3.14 upstream; tolerate its absence on 3.14.
ENV UV_PYTHON_PREFERENCE=only-system
RUN uv pip install --system torch tensorflow || true
